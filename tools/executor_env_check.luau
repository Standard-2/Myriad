local lookup = {}
for _, name in CHECKS do
    lookup[name] = true
end

local results = {
    missing = {},
    found = {},
}

for name, value in getgenv() do
    if type(name) == "string" then
        if not lookup[name] then
            table.insert(results.missing, name)
        else
            table.insert(results.found, name)
        end
    end
end

table.sort(results.missing)
table.sort(results.found)

print("Missing:")
for _, name in results.missing do
    print(`[+] {name}`)
end

return results
