{
    "deployment": {
        "github": {
            "owner": "Standard-2",
            "repo": "Myriad"
        }
    },
    
    "buildConfigs": [
        {
            "name": "Debug",
            "promptVersion": false,
            "promptDeploy": false,
            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/targets/unminified.json",
            "input": "src/main.luau",
            "output": "generated/debug/myriad.client.luau",
            "pipelineHooks": {
                "preAllBuilds": {
                    "command": "lune run pipeline/hooks/kacParser/init CHANGELOG.md packages/CHANGELOG.json"
                }
            }
        },
        {
            "name": "Tests",
            "inputDir": "tests",
            "outputDir": "generated/tests",
            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/targets/unminified.json"
        },
        {
            "name": "Beta",
            "promptVersion": true,
            "promptDeploy": true,
            "prerelease": true,
            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/targets/stable.json",
            "input": "src/main.luau",
            "output": "generated/beta/myriad.luau",
            "pipelineHooks": {
                "preAllBuilds": {
                    "command": "lune run pipeline/hooks/kacParser/init CHANGELOG.md packages/CHANGELOG.json"
                }
            },
            "variants": [
                {
                    "name": "Legacy-Support",
                    "darkluaConfig": "pipeline/targets/stable.json",
                    "output": "generated/beta/pre.luau"
                },
                {
                    "name": "Unminified",
                    "darkluaConfig": "pipeline/targets/unminified.json",
                    "output": "generated/beta/myriad-unminified.luau"
                },
                {
                    "name": "API",
                    "input": "src/api/init.luau",
                    "darkluaConfig": "pipeline/targets/stable.json",
                    "output": "generated/beta/api.luau"
                }
            ]
        },
        {
            "name": "Release",
            "promptVersion": true,
            "promptDeploy": true,
            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/targets/stable.json",
            "input": "src/main.luau",
            "output": "generated/release/myriad.luau",
            "pipelineHooks": {
                "preAllBuilds": {
                    "command": "lune run pipeline/hooks/kacParser/init CHANGELOG.md packages/CHANGELOG.json"
                }
            },
            "variants": [
                {
                    "name": "Legacy-Support",
                    "darkluaConfig": "pipeline/targets/stable.json",
                    "output": "generated/release/release.luau",
                    "frame": "pipeline/frames/legacy.luau"
                },
                {
                    "name": "Unminified",
                    "darkluaConfig": "pipeline/targets/unminified.json",
                    "output": "generated/release/myriad-unminified.luau"
                },
                {
                    "name": "API",
                    "input": "src/api/init.luau",
                    "darkluaConfig": "pipeline/targets/stable.json",
                    "output": "generated/release/api.luau"
                }
            ]
        }
    ]
}
